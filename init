#!/usr/bin/env bash
#
# init — Instalador de doctyp (generador de informes Typst · SLEP Chinchorro).
#
# Asegura las dependencias (Python 3, Typst), instala las fuentes oficiales y crea los symlinks
# del comando (doctyp + alias ty/tp/dt) en ~/.local/bin. Pensado para ejecutarse una sola vez
# tras clonar el repositorio. Soporta Ubuntu, Debian, Fedora/RHEL, Arch, openSUSE y macOS.
# En Windows usa el instalador equivalente init.ps1 (PowerShell).
#
# Uso:
#   ./init
#
set -euo pipefail

# Directorio real del repositorio (donde vive este script).
REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BIN_DIR="$HOME/.local/bin"
FONT_DIR="$HOME/.local/share/fonts"
ALIASES=(doctyp ty tp dt)

info()  { printf '\033[1;34m==>\033[0m %s\n' "$*"; }
ok()    { printf '\033[1;32m  ✔\033[0m %s\n' "$*"; }
warn()  { printf '\033[1;33m  ⚠\033[0m %s\n' "$*"; }
err()   { printf '\033[1;31mERROR:\033[0m %s\n' "$*" >&2; }

# --------------------------------------------------------------------------
# Detección de distribución
# --------------------------------------------------------------------------
detect_distro() {
  if [ -r /etc/os-release ]; then
    # shellcheck disable=SC1091
    . /etc/os-release
    case "${ID:-}${ID_LIKE:-}" in
      *fedora*|*rhel*|*centos*) echo "fedora" ;;
      *ubuntu*)                 echo "ubuntu" ;;
      *debian*)                 echo "debian" ;;
      *arch*)                   echo "arch" ;;
      *suse*)                   echo "suse" ;;
      *)                        echo "unknown" ;;
    esac
  elif [ "$(uname -s)" = "Darwin" ]; then
    echo "macos"
  else
    echo "unknown"
  fi
}

DISTRO="$(detect_distro)"
info "Distribución detectada: ${DISTRO}"

# Gestor de paquetes según distro.
case "$DISTRO" in
  fedora)         PM_INSTALL="sudo dnf install -y" ;;
  ubuntu|debian)  PM_INSTALL="sudo apt-get install -y"; sudo apt-get update -qq || true ;;
  arch)           PM_INSTALL="sudo pacman -S --noconfirm" ;;
  suse)           PM_INSTALL="sudo zypper install -y" ;;
  macos)          if command -v brew >/dev/null 2>&1; then PM_INSTALL="brew install"; else PM_INSTALL=""; fi ;;
  *)              PM_INSTALL="" ;;
esac

# En macOS las fuentes de usuario van a ~/Library/Fonts.
[ "$DISTRO" = "macos" ] && FONT_DIR="$HOME/Library/Fonts"

# Instala un paquete del sistema (o avisa si no hay gestor soportado).
pkg_install() {
  local pkg="$1"
  if [ -z "$PM_INSTALL" ]; then
    warn "Distribución no soportada para instalación automática; instala '$pkg' manualmente."
    return 1
  fi
  info "Instalando '$pkg'..."
  # shellcheck disable=SC2086
  $PM_INSTALL "$pkg"
}

# --------------------------------------------------------------------------
# 1) Python 3
# --------------------------------------------------------------------------
info "Comprobando Python 3..."
if command -v python3 >/dev/null 2>&1; then
  ok "Python 3 presente: $(python3 --version 2>&1)"
else
  pkg_install python3 && ok "Python 3 instalado." || err "No se pudo instalar Python 3."
fi

# --------------------------------------------------------------------------
# 2) Typst
# --------------------------------------------------------------------------
info "Comprobando Typst..."
if command -v typst >/dev/null 2>&1; then
  ok "Typst presente: $(typst --version 2>&1)"
else
  case "$DISTRO" in
    fedora)
      pkg_install typst && ok "Typst instalado." || \
        warn "No se pudo instalar Typst con dnf. Alternativa: 'cargo install typst-cli'."
      ;;
    arch)
      pkg_install typst && ok "Typst instalado." || \
        warn "No se pudo instalar Typst con pacman. Alternativa: 'cargo install typst-cli'."
      ;;
    macos)
      pkg_install typst && ok "Typst instalado." || \
        warn "No se pudo instalar Typst con brew. Alternativa: 'cargo install typst-cli'."
      ;;
    ubuntu|debian|suse)
      # Typst no está en los repos estándar de Debian/Ubuntu/SUSE; se intenta snap o cargo.
      if command -v snap >/dev/null 2>&1; then
        info "Instalando Typst vía snap..."
        sudo snap install typst --classic && ok "Typst instalado (snap)." || \
          warn "Falló snap. Instala Typst con 'cargo install typst-cli' o desde GitHub releases."
      else
        warn "Typst no está en los repos de ${DISTRO}. Instálalo con uno de:"
        warn "  sudo snap install typst --classic"
        warn "  cargo install typst-cli"
        warn "  o binario desde https://github.com/typst/typst/releases"
      fi
      ;;
    *)
      warn "Instala Typst manualmente: https://github.com/typst/typst/releases"
      ;;
  esac
fi

# --------------------------------------------------------------------------
# 3) Fuentes oficiales (Museo Sans + gobCL)
# --------------------------------------------------------------------------
info "Instalando fuentes oficiales en ${FONT_DIR}..."
mkdir -p "$FONT_DIR/doctyp"
copied=0
for d in "$REPO_DIR/museo-sans" "$REPO_DIR/GobCLFontsFiles"; do
  [ -d "$d" ] || continue
  for f in "$d"/*.otf "$d"/*.ttf; do
    [ -e "$f" ] || continue
    cp -f "$f" "$FONT_DIR/doctyp/" && copied=$((copied + 1))
  done
done
if [ "$copied" -gt 0 ]; then
  command -v fc-cache >/dev/null 2>&1 && fc-cache -f "$FONT_DIR" >/dev/null 2>&1 || true
  ok "Fuentes instaladas (${copied} archivos) y caché actualizada."
else
  warn "No se encontraron archivos de fuente en el repositorio."
fi

# --------------------------------------------------------------------------
# 4) Symlinks del comando (doctyp + alias)
# --------------------------------------------------------------------------
info "Creando symlinks en ${BIN_DIR}..."
chmod +x "$REPO_DIR/doctyp.py"
mkdir -p "$BIN_DIR"
for n in "${ALIASES[@]}"; do
  ln -sf "$REPO_DIR/doctyp.py" "$BIN_DIR/$n"
  ok "$n → $REPO_DIR/doctyp.py"
done

# --------------------------------------------------------------------------
# 5) Datos del autor (settings.json -> local.author)
# --------------------------------------------------------------------------
# Se piden interactivamente y se guardan globalmente; al crear documentos, doctyp los usa por
# defecto. Se delega en el propio script (config-author) para tener una única fuente de la lógica.
# Volver a ejecutar `init` permite cambiarlos (en blanco se mantiene el valor actual).
PYTHON="$(command -v python3 || command -v python || true)"
if [ -n "$PYTHON" ] && [ -t 0 ]; then
  info "Configurando datos del autor (se guardan en settings.json)..."
  "$PYTHON" "$REPO_DIR/doctyp.py" config-author || warn "No se pudo configurar el autor."
else
  warn "Omito la configuración del autor (sin Python o sin terminal interactiva)."
  warn "Configúralo luego con:  doctyp config-author"
fi

# --------------------------------------------------------------------------
# 6) PATH
# --------------------------------------------------------------------------
if printf '%s' ":$PATH:" | grep -q ":$BIN_DIR:"; then
  ok "${BIN_DIR} ya está en el PATH."
else
  warn "${BIN_DIR} no está en el PATH. Añádelo a tu shell y reabre la terminal:"
  printf '      \033[1mecho '\''export PATH="$HOME/.local/bin:$PATH"'\'' >> ~/.bashrc\033[0m\n'
fi

echo
ok "Instalación completada. Prueba:  doctyp list"
